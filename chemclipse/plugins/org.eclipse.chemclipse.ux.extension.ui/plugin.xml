<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.eclipse.chemclipse.ux.extension.ui.welcometile" name="Welcome Tile" schema="schema/org.eclipse.chemclipse.ux.extension.ui.welcometile.exsd"/>
   <extension
         id="org.eclipse.chemclipse.ux.extension.ui.modelContribution"
         point="org.eclipse.e4.workbench.model">
      <fragment
            uri="fragment.e4xmi">
      </fragment>
   </extension>
   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            category="org.eclipse.chemclipse.rcp.app.ui.preferences.settingsPreferencePage"
            class="org.eclipse.chemclipse.ux.extension.ui.preferences.PreferencePage"
            id="org.eclipse.chemclipse.ux.extension.ui.preferencePage"
            name="Drive Settings">
      </page>
      <page
            category="org.eclipse.chemclipse.rcp.app.ui.preferences.settingsPreferencePage"
            class="org.eclipse.chemclipse.ux.extension.ui.preferences.PreferencePageUserLocations"
            id="org.eclipse.chemclipse.ux.extension.ui.preferencePageUserLocations"
            name="User Locations">
      </page>      
   </extension>
   <extension
         point="org.eclipse.ui.cheatsheets.cheatSheetContent">
      <category
            name="Basics"
            id="org.eclipse.chemclipse.ux.extension.ui.cheatsheet.basics">
      </category>
      <cheatsheet
            name="Basic Peak Detection and Integration"
            category="org.eclipse.chemclipse.ux.extension.ui.cheatsheet.basics"
            contentFile="cheatsheets/PeakDetectionIntegration.xml"
            id="org.eclipse.chemclipse.ux.extension.ui.cheatsheet.PeakDetectionIntegration">
         <description>
            This cheat sheet will guide you through basic peak detection and integration.
         </description>
      </cheatsheet>
   </extension>
</plugin>
